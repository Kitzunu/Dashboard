# AzerothCore executable paths
WORLDSERVER_PATH=C:\AzerothCore\worldserver.exe
AUTHSERVER_PATH=C:\AzerothCore\authserver.exe

# Host and game port used for server latency measurement (TCP ping).
# Only needed if your worldserver is NOT on localhost or uses a non-default port.
WORLDSERVER_HOST=
WORLDSERVER_PORT=

# Working directories for the servers (defaults to the exe's directory if omitted)
WORLDSERVER_DIR=
AUTHSERVER_DIR=

# ── Multiple Worldservers ──────────────────────────────────────────────────────
# To manage multiple worldserver instances (e.g. multiple realms), create a
# worldservers.json file in the project root.  See worldservers.json.example.
# When worldservers.json is present the WORLDSERVER_* env vars above are ignored;
# all worldserver settings come from that file instead.
# The auth server remains configured via AUTHSERVER_PATH above.

# Extra config directory (optional) — all .conf files found here (and in subdirectories)
# are automatically added to the Config page as editable tabs.
# If set, this is the only source of config files; WORLDSERVER_PATH/AUTHSERVER_PATH
# are only used as a fallback when CONFIG_PATH is not set.
CONFIG_PATH=

# Database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=acore
DB_PASSWORD=acore
AUTH_DB=acore_auth
WORLD_DB=acore_world
CHARACTERS_DB=acore_characters

# Dashboard database name (created automatically if it doesn't exist)
DASHBOARD_DB=acore_dashboard

# Audit log retention — delete entries older than this many days.
# Set to 0 or leave blank to keep logs forever.
AUDIT_LOG_RETENTION_DAYS=90

# Auto-logout after this many minutes of inactivity.
# Set to 0 or leave blank to disable.
IDLE_TIMEOUT_MINUTES=30

# JWT secret — change this to something random!
JWT_SECRET=change-this-to-a-random-secret

# Backend port
PORT=3001

# Server agent port — the standalone process that keeps game servers running
# independently of the dashboard backend. Change if 3002 is already in use.
AGENT_PORT=3002

# Shared secret between the dashboard backend and the server agent.
# Change this to a random string for security.
AGENT_SECRET=changeme

# IP allowlist — comma-separated list of IPs allowed to reach the backend.
# Defaults to localhost only if this variable is omitted.
# Add your server's LAN/WAN IP here if you need remote access.
# Example: ALLOWED_IPS=127.0.0.1,::1,192.168.1.50
ALLOWED_IPS=127.0.0.1,::1

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Path to WotLK (3.3.5a) client DBC files directory (the DBFilesClient folder).
# Required for human-readable map and zone names in Lag Reports.
# Leave blank to fall back to "Map {id}" / "Area {id}" placeholders.
# Example (Windows): DBC_PATH=C:\World of Warcraft\Data\enUS\DBFilesClient
# Example (Linux):   DBC_PATH=/opt/wow/Data/enUS/DBFilesClient
DBC_PATH=

# Scheduled task settings
# Directory where database backups are saved (created automatically if missing).
# Defaults to a 'backups' folder in the project root.
BACKUP_PATH=

# Default directory for character dump exports (.pdump write).
# When set, the "Save on server" option in the Export Dump modal pre-fills this path
# so users don't have to type a directory every time — they only need to add a filename.
# Leave blank to require a full path to be entered manually each time.
# Example (Windows): PDUMP_OUTPUT_PATH=C:\AzerothCore\dumps
# Example (Linux):   PDUMP_OUTPUT_PATH=/opt/azerothcore/dumps
PDUMP_OUTPUT_PATH=./pdump

# Path to the mysqldump binary. Only needed if mysqldump is not in your system PATH.
MYSQLDUMP_PATH=

# Discord webhook URL for alert notifications (server offline, resource threshold, agent disconnect).
# Leave blank to disable Discord alerts entirely.
DISCORD_WEBHOOK_URL=
